# Python
__pycache__/
*.pyc
*.pyo

# Database files
*.db
*.db-shm
*.db-wal

# Environment / secrets
company.env
*.env

# Install state
.install_complete
.install_progress.json

# Logs — ignore the whole directory contents (rotated .log.1, .log.N.gz,
# .pid, crash dumps, etc. — none of them belong in git). Tracked config
# files in logs/ should use an explicit `!logs/KEEP.md`-style allowlist.
logs/*
!logs/.gitkeep

# Runtime state / caches
data/.cve_cache.json
data/.sentinel_alerted_*
data/.patches_state.json
data/librarian_latest.json
data/morning_report.json
data/patches_latest.json
data/backup_log.json
data/backup_status.json
data/fidget_latest.json
data/audit_result.json
data/package_manifest.json
data/timekeeper_status.json
config/package_manifest.json
.known_good/

# Stale backup artifacts from prior refactors (dbleak fix, etc.)
*.pre_dbleak_bak
*.pre_*_bak
*.bak

# Runtime state files not previously covered
data/.admin_overrides.json
data/archives/

# Scoop / trigger files
data/scoop_trigger.json
data/suggestions.json
data/post_deploy_watch.json
logs/archive/
logs/*.bak.*
data/.company_write.lock
data/.monitor_registry.json
